## ЧАСТЬ 2 — gRPC

### 2.1 Когда выбирать gRPC
```
✅ gRPC уместен когда:
- Сервис-сервис коммуникация внутри инфраструктуры
- Нужна низкая латентность (Protobuf в 3-10x компактнее JSON)
- Нужен streaming (unary не хватает)
- Команды используют разные языки — proto как lingua franca
- Строгий типизированный контракт критичен

❌ gRPC не уместен когда:
- Публичный API для браузерных клиентов (нет нативной поддержки)
- Нужна простая отладка через curl/Postman
- Команда не знакома с Protobuf
```

### 2.2 Proto файлы — структура и конвенции

*Причина*: `.proto` файл — единственный источник правды для контракта.
Версия пакета в proto — основа обратной совместимости.
```protobuf
// proto/user/v1/user_service.proto
syntax = "proto3";

// Версия в имени пакета — критично для обратной совместимости
package user.v1;

option python_out = "app/grpc/generated";

import "google/protobuf/timestamp.proto";
import "google/protobuf/empty.proto";

// Сервис — группирует связанные RPC методы
service UserService {
    // Unary RPC — один запрос, один ответ
    rpc GetUser(GetUserRequest) returns (UserResponse);
    rpc CreateUser(CreateUserRequest) returns (UserResponse);
    rpc UpdateUser(UpdateUserRequest) returns (UserResponse);
    rpc DeleteUser(DeleteUserRequest) returns (google.protobuf.Empty);

    // Server streaming — один запрос, поток ответов
    rpc ListUsers(ListUsersRequest) returns (stream UserResponse);

    // Client streaming — поток запросов, один ответ
    rpc BulkCreateUsers(stream CreateUserRequest) returns (BulkCreateResponse);

    // Bidirectional streaming — поток запросов и поток ответов
    rpc SyncUsers(stream UserSyncRequest) returns (stream UserSyncResponse);
}

message GetUserRequest {
    string user_id = 1;  // UUID как string
}

message CreateUserRequest {
    string email = 1;
    string full_name = 2;
    string password = 3;
}

message UpdateUserRequest {
    string user_id = 1;
    // optional — поле может отсутствовать (partial update)
    optional string full_name = 2;
    optional bool is_active = 3;
}

message DeleteUserRequest {
    string user_id = 1;
}

message UserResponse {
    string id = 1;
    string email = 2;
    string full_name = 3;
    bool is_active = 4;
    google.protobuf.Timestamp created_at = 5;
}

message ListUsersRequest {
    int32 page = 1;
    int32 size = 2;
    bool include_inactive = 3;
}

message BulkCreateResponse {
    int32 created_count = 1;
    repeated string failed_emails = 2;
}
```

### 2.3 gRPC Error codes — стандартные коды вместо HTTP статусов

*Причина*: gRPC имеет свои 16 статус кодов. Маппинг на HTTP неоднозначен —
используй gRPC коды напрямую для gRPC сервисов.
```python
# app/grpc/servicers/user_servicer.py
import grpc
from grpc import ServicerContext

from app.domain.exceptions import UserNotFoundError, UserAlreadyExistsError
from app.grpc.generated.user.v1 import user_service_pb2_grpc, user_service_pb2


class UserServicer(user_service_pb2_grpc.UserServiceServicer):
    """gRPC реализация UserService."""

    def __init__(self, user_service: UserService) -> None:
        self._service = user_service

    async def GetUser(
        self,
        request: user_service_pb2.GetUserRequest,
        context: ServicerContext,
    ) -> user_service_pb2.UserResponse:
        try:
            user = await self._service.get_by_id(request.user_id)
        except UserNotFoundError as e:
            # NOT_FOUND — аналог HTTP 404
            await context.abort(grpc.StatusCode.NOT_FOUND, str(e))

        return self._to_proto(user)

    async def CreateUser(
        self,
        request: user_service_pb2.CreateUserRequest,
        context: ServicerContext,
    ) -> user_service_pb2.UserResponse:
        try:
            user = await self._service.create(
                request.email, request.full_name, request.password
            )
        except UserAlreadyExistsError as e:
            # ALREADY_EXISTS — аналог HTTP 409
            await context.abort(grpc.StatusCode.ALREADY_EXISTS, str(e))
        except ValueError as e:
            # INVALID_ARGUMENT — аналог HTTP 400
            await context.abort(grpc.StatusCode.INVALID_ARGUMENT, str(e))

        return self._to_proto(user)

    async def ListUsers(
        self,
        request: user_service_pb2.ListUsersRequest,
        context: ServicerContext,
    ):
        """Server streaming — отдаём пользователей по одному."""
        async for user in self._service.iter_users(
            page=request.page,
            size=request.size,
        ):
            yield self._to_proto(user)

    async def BulkCreateUsers(
        self,
        request_iterator,
        context: ServicerContext,
    ) -> user_service_pb2.BulkCreateResponse:
        """Client streaming — принимаем поток запросов на создание."""
        created = 0
        failed = []

        async for request in request_iterator:
            try:
                await self._service.create(
                    request.email, request.full_name, request.password
                )
                created += 1
            except UserAlreadyExistsError:
                failed.append(request.email)

        return user_service_pb2.BulkCreateResponse(
            created_count=created,
            failed_emails=failed,
        )

    @staticmethod
    def _to_proto(user: User) -> user_service_pb2.UserResponse:
        """Маппинг domain entity → proto message."""
        from google.protobuf.timestamp_pb2 import Timestamp
        ts = Timestamp()
        ts.FromDatetime(user.created_at)
        return user_service_pb2.UserResponse(
            id=str(user.id),
            email=user.email,
            full_name=user.full_name,
            is_active=user.is_active,
            created_at=ts,
        )
```

**Маппинг gRPC статус кодов:**
```python
# Справочник: domain exception → gRPC status code
DOMAIN_TO_GRPC = {
    UserNotFoundError:      grpc.StatusCode.NOT_FOUND,         # ресурс не найден
    UserAlreadyExistsError: grpc.StatusCode.ALREADY_EXISTS,    # дубликат
    PermissionDeniedError:  grpc.StatusCode.PERMISSION_DENIED, # нет прав
    ValidationError:        grpc.StatusCode.INVALID_ARGUMENT,  # невалидные данные
    UnauthenticatedError:   grpc.StatusCode.UNAUTHENTICATED,   # нет токена
    RateLimitError:         grpc.StatusCode.RESOURCE_EXHAUSTED,# rate limit
    TimeoutError:           grpc.StatusCode.DEADLINE_EXCEEDED, # таймаут
}
```

### 2.4 Обратная совместимость в proto

*Причина*: proto использует номера полей, не имена для сериализации.
Нарушение совместимости = молчаливая порча данных у клиентов.
```protobuf
// ✅ NON-BREAKING — безопасно:
message UserResponse {
    string id = 1;
    string email = 2;
    string full_name = 3;
    bool is_active = 4;
    // Добавить новое поле с новым номером — безопасно
    string avatar_url = 5;
    google.protobuf.Timestamp updated_at = 6;
}

// ❌ BREAKING — ЗАПРЕЩЕНО без смены версии пакета:
message UserResponse {
    string id = 1;
    // string email = 2; — УДАЛЕНО → номер 2 теперь "зарезервирован мусором"
    string full_name = 3;
    string user_email = 4;  // переиспользование номера 2 — КАТАСТРОФА
}
```
```protobuf
// Правильный способ удалить поле — reserved
message UserResponse {
    string id = 1;
    reserved 2;               // номер зарезервирован — нельзя переиспользовать
    reserved "email";         // имя зарезервировано
    string full_name = 3;
    bool is_active = 4;
}
```

