## Правила зависимостей между слоями

# КРИТИЧЕСКИ ВАЖНО — нарушение = сломанная архитектура:

✅ Правильное направление зависимостей (внутри Odoo аддона):
```python
# iup_core/controllers/iup_api.py — controller знает о service
from odoo.addons.iup_core.services.plan_validator import PlanValidatorService

# iup_core/services/plan_validator.py — service работает с моделями через self.env
# НЕ импортирует модели напрямую — только через Odoo ORM registry
plan = self.env['iup.plan'].browse(plan_id)

# iup_llm/services/mcp_client.py — реализует интерфейс из iup_core
from odoo.addons.iup_core.services.interfaces.llm_agent import AbstractLLMAgent
```

❌ Запрещённые паттерны:
```python
# services/ — НИКОГДА не импортирует из controllers/
from odoo.addons.iup_core.controllers.iup_api import IupApiController  # ЗАПРЕЩЕНО

# Прямой SQL в сервисах — НИКОГДА
self.env.cr.execute("SELECT * FROM iup_plan")  # ЗАПРЕЩЕНО без крайней нужды

# Бизнес-логика в контроллерах — НИКОГДА
class IupApiController(http.Controller):
    def validate(self):
        if credits > 30:  # ЗАПРЕЩЕНО — логика принадлежит PlanValidatorService
            ...

# iup_approval не импортирует из iup_portal — аддоны зависят только вниз
from odoo.addons.iup_portal.controllers.portal import ...  # ЗАПРЕЩЕНО
```

