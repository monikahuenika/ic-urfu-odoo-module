<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Демо учебный план для студента -->
        <record id="plan_demo_student_1" model="ic.urfu.plan">
            <field name="student_id" ref="user_demo_student"/>
            <field name="student_name">Иванов Петр Сергеевич</field>
            <field name="institute">Институт естественных наук и математики</field>
            <field name="department">Департамент информационных технологий и автоматики</field>
            <field name="specialty_code">09.04.04 - Программная инженерия</field>
            <field name="program">Разработка программно-информационных систем</field>
            <field name="supervisor">Петров Иван Александрович</field>
            <field name="research_area">Разработка систем искусственного интеллекта для анализа медицинских данных</field>
            <field name="thesis_topic">Применение методов глубокого обучения для диагностики заболеваний по медицинским изображениям</field>
            <field name="deadline">Май 2027</field>
            <field name="rop_name">Сидоров Александр Петрович</field>
            <field name="year">2025</field>
            <field name="state">draft</field>
        </record>

        <!-- Семестр 1 -->
        <record id="semester_1" model="ic.urfu.semester">
            <field name="plan_id" ref="plan_demo_student_1"/>
            <field name="number">1</field>
            <field name="academic_year">2025 / 2026</field>
            <field name="mandatory_subject_ids" eval="[(6, 0, [
                ref('subject_mandatory_1'),
                ref('subject_mandatory_2'),
                ref('subject_mandatory_3')
            ])]"/>
            <field name="elective_subject_ids" eval="[(6, 0, [
                ref('subject_elective_1')
            ])]"/>
        </record>

        <!-- Семестр 2 -->
        <record id="semester_2" model="ic.urfu.semester">
            <field name="plan_id" ref="plan_demo_student_1"/>
            <field name="number">2</field>
            <field name="academic_year">2025 / 2026</field>
            <field name="mandatory_subject_ids" eval="[(6, 0, [
                ref('subject_mandatory_4'),
                ref('subject_mandatory_5')
            ])]"/>
            <field name="elective_subject_ids" eval="[(6, 0, [
                ref('subject_elective_2'),
                ref('subject_elective_3')
            ])]"/>
        </record>

        <!-- Семестр 3 -->
        <record id="semester_3" model="ic.urfu.semester">
            <field name="plan_id" ref="plan_demo_student_1"/>
            <field name="number">3</field>
            <field name="academic_year">2026 / 2027</field>
            <field name="mandatory_subject_ids" eval="[(6, 0, [
                ref('subject_mandatory_6'),
