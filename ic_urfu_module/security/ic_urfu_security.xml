<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Категория модуля -->
        <record id="module_category_ic_urfu" model="ir.module.category">
            <field name="name">IC UrFU</field>
            <field name="description">Individual Education Plans for UrFU</field>
            <field name="sequence">100</field>
        </record>

        <!-- Группа: Студент -->
        <record id="group_ic_urfu_student" model="res.groups">
            <field name="name">Студент</field>
            <field name="category_id" ref="module_category_ic_urfu"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Студенты могут создавать и редактировать свои учебные планы</field>
        </record>

        <!-- Группа: Преподаватель -->
        <record id="group_ic_urfu_teacher" model="res.groups">
            <field name="name">Преподаватель</field>
            <field name="category_id" ref="module_category_ic_urfu"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Преподаватели могут проверять и утверждать учебные планы студентов</field>
        </record>

        <!-- Правила доступа для студентов (только свои планы) -->
        <record id="ic_urfu_plan_rule_student" model="ir.rule">
            <field name="name">Студент видит только свои планы</field>
            <field name="model_id" ref="model_ic_urfu_plan"/>
            <field name="domain_force">[('student_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ic_urfu_student'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Правила доступа для преподавателей (все планы) -->
        <record id="ic_urfu_plan_rule_teacher" model="ir.rule">
            <field name="name">Преподаватель видит все планы</field>
            <field name="model_id" ref="model_ic_urfu_plan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ic_urfu_teacher'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
