<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================= -->
    <!-- ДИСЦИПЛИНЫ (SUBJECTS/COURSES) -->
    <!-- ========================================= -->

    <!-- Tree View для дисциплин -->
    <record id="view_ic_urfu_subject_tree" model="ir.ui.view">
        <field name="name">ic.urfu.subject.tree</field>
        <field name="model">ic.urfu.subject</field>
        <field name="arch" type="xml">
            <tree string="Дисциплины" editable="bottom" decoration-primary="subject_type=='mandatory'" decoration-info="subject_type=='elective'">
                <field name="name"/>
                <field name="subject_type" widget="badge" decoration-primary="subject_type=='mandatory'" decoration-info="subject_type=='elective'"/>
                <field name="hours"/>
                <field name="credits"/>
                <field name="control" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- Form View для дисциплин -->
    <record id="view_ic_urfu_subject_form" model="ir.ui.view">
        <field name="name">ic.urfu.subject.form</field>
        <field name="model">ic.urfu.subject</field>
        <field name="arch" type="xml">
            <form string="Дисциплина">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Название дисциплины..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="subject_type" widget="radio"/>
                            <field name="control"/>
                        </group>
                        <group>
                            <label for="hours"/>
                            <div class="o_row">
                                <field name="hours"/>
                                <span>часов</span>
                            </div>
                            <label for="credits"/>
                            <div class="o_row">
                                <field name="credits"/>
                                <span>ЗЕТ</span>
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View для дисциплин -->
    <record id="view_ic_urfu_subject_kanban" model="ir.ui.view">
        <field name="name">ic.urfu.subject.kanban</field>
        <field name="model">ic.urfu.subject</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="subject_type"/>
                <field name="hours"/>
                <field name="credits"/>
                <field name="control"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                                <span class="badge" t-att-class="record.subject_type.raw_value == 'mandatory' ? 'badge-primary' : 'badge-info'">
                                    <field name="subject_type"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span><i class="fa fa-clock-o"/> <field name="hours"/> ч</span>
                                    <span class="ml8"><i class="fa fa-trophy"/> <field name="credits"/> ЗЕТ</span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="control" widget="badge"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action для дисциплин -->
    <record id="action_ic_urfu_subject" model="ir.actions.act_window">
        <field name="name">Дисциплины</field>
        <field name="res_model">ic.urfu.subject</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Создайте первую дисциплину
            </p>
            <p>
                Управляйте справочником дисциплин (курсов) для составления учебных планов.
            </p>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- ИНДИВИДУАЛЬНЫЙ ПЛАН -->
    <!-- ========================================= -->

    <!-- Tree View для планов -->
    <record id="view_ic_urfu_plan_tree" model="ir.ui.view">
        <field name="name">ic.urfu.plan.tree</field>
        <field name="model">ic.urfu.plan</field>
        <field name="arch" type="xml">
            <tree string="Индивидуальные планы"
                  decoration-info="state=='draft'"
                  decoration-warning="state=='submitted'"
                  decoration-success="state=='approved'"
                  decoration-muted="state=='generated'">
                <field name="name"/>
                <field name="student_name"/>
                <field name="program"/>
                <field name="year"/>
                <field name="state" widget="badge"
                       decoration-info="state=='draft'"
                       decoration-warning="state=='submitted'"
                       decoration-success="state=='approved'"
                       decoration-muted="state=='generated'"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View для планов -->
    <record id="view_ic_urfu_plan_kanban" model="ir.ui.view">
        <field name="name">ic.urfu.plan.kanban</field>
        <field name="model">ic.urfu.plan</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="student_name"/>
                <field name="program"/>
                <field name="year"/>
                <field name="state"/>
                <field name="document_file"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb16">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="student_name"/></strong>
                                    <br/>
                                    <small class="text-muted"><field name="program"/></small>
                                </div>
                                <field name="state" widget="label_selection"
                                       options="{'classes': {'draft': 'info', 'submitted': 'warning', 'approved': 'success', 'rejected': 'danger', 'generated': 'secondary'}}"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span><i class="fa fa-calendar"/> <field name="year"/></span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span t-if="record.document_file.raw_value" class="badge badge-success">
                                        <i class="fa fa-file-word-o"/> Документ готов
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View для планов -->
    <record id="view_ic_urfu_plan_search" model="ir.ui.view">
        <field name="name">ic.urfu.plan.search</field>
        <field name="model">ic.urfu.plan</field>
        <field name="arch" type="xml">
            <search string="Поиск планов">
                <field name="student_name" string="Студент"
                       filter_domain="[('student_name', 'ilike', self)]"/>
                <field name="program" string="Программа"
                       filter_domain="[('program', 'ilike', self)]"/>
                <field name="year" string="Год"/>

                <filter string="Черновики" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="На проверке" name="filter_submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Одобрено" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Отклонено" name="filter_rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="Документ создан" name="filter_generated" domain="[('state', '=', 'generated')]"/>

                <separator/>
                <filter string="Мои планы" name="filter_my_plans" domain="[('student_id', '=', uid)]"
                        groups="ic_urfu_module.group_ic_urfu_student"/>

                <group expand="0" string="Группировка">
                    <filter string="Статус" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Год" name="group_by_year" context="{'group_by': 'year'}"/>
                    <filter string="Программа" name="group_by_program" context="{'group_by': 'program'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Form View для плана -->
    <record id="view_ic_urfu_plan_form" model="ir.ui.view">
        <field name="name">ic.urfu.plan.form</field>
        <field name="model">ic.urfu.plan</field>
        <field name="arch" type="xml">
            <form string="Индивидуальный учебный план">
                <header>
                    <!-- Кнопки для студента -->
                    <button name="action_submit" string="Отправить на проверку" type="object"
                            invisible="state not in ['draft', 'rejected']" class="oe_highlight" icon="fa-paper-plane"
                            groups="ic_urfu_module.group_ic_urfu_student"/>
                    <button name="action_draft" string="Вернуть в черновик" type="object"
                            invisible="state not in ['submitted', 'rejected']"
                            groups="ic_urfu_module.group_ic_urfu_student" icon="fa-undo"/>
                    <button name="unlink" string="Удалить" type="object"
                            invisible="state not in ['draft', 'rejected']"
                            groups="ic_urfu_module.group_ic_urfu_student" icon="fa-trash"
                            confirm="Вы уверены, что хотите удалить этот план?"/>

                    <!-- Кнопки для преподавателя -->
                    <button name="action_approve" string="Утвердить план" type="object"
                            invisible="state != 'submitted'" class="btn-success" icon="fa-check"
                            groups="ic_urfu_module.group_ic_urfu_teacher"/>
                    <button name="action_reject" string="Отклонить план" type="object"
                            invisible="state != 'submitted'" class="btn-danger" icon="fa-times"
                            groups="ic_urfu_module.group_ic_urfu_teacher"/>

                    <!-- Генерация документа (для обеих ролей) -->
                    <button name="action_generate_document" string="Сгенерировать документ" type="object"
                            class="btn-success" icon="fa-file-word-o"
                            invisible="state != 'approved'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,generated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(base.action_attachment)d" type="action" class="oe_stat_button" icon="fa-download"
                                invisible="not document_file"
                                context="{'default_res_model': 'ic.urfu.plan', 'default_res_id': id}">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Документ</span>
                                <span class="o_stat_text">готов</span>
                            </div>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Черновик" bg_color="bg-info" invisible="state != 'draft'"/>
                    <widget name="web_ribbon" title="На проверке" bg_color="bg-warning" invisible="state != 'submitted'"/>
                    <widget name="web_ribbon" title="Одобрено" bg_color="bg-success" invisible="state != 'approved'"/>
                    <widget name="web_ribbon" title="Отклонено" bg_color="bg-danger" invisible="state != 'rejected'"/>
                    <widget name="web_ribbon" title="Документ создан" bg_color="text-bg-secondary" invisible="state != 'generated'"/>

                    <!-- Поле для скачивания документа -->
                    <div class="alert alert-success text-center" invisible="not document_file" style="margin: 10px;">
                        <i class="fa fa-file-word-o fa-3x mb8"/>
                        <h4>Документ сгенерирован!</h4>
                        <field name="document_file" filename="document_filename" widget="binary" class="btn btn-primary"/>
                    </div>

                    <div class="oe_title">
                        <label for="student_name" string="Студент"/>
                        <h1>
                            <field name="student_name" placeholder="Иванова Ивана Ивановича"
                                   readonly="state not in ['draft', 'rejected']"/>
                        </h1>
                        <field name="student_short_name" readonly="1" class="text-muted"/>
                    </div>

                    <!-- Комментарий преподавателя -->
                    <div class="alert alert-warning" invisible="not teacher_comment or state not in ['rejected']">
                        <strong>Комментарий преподавателя:</strong>
                        <p><field name="teacher_comment" readonly="1" nolabel="1"/></p>
                    </div>

                    <group>
                        <group string="Базовая информация" icon="fa-user">
                            <field name="year" widget="text" readonly="state not in ['draft', 'rejected']"/>
                            <field name="rop_name" placeholder="И.И. Иванов" readonly="state not in ['draft', 'rejected']"/>
                            <field name="supervisor" placeholder="Научный руководитель (опционально)" readonly="state not in ['draft', 'rejected']"/>
                        </group>
                        <group string="Даты и сроки" icon="fa-calendar">
                            <field name="deadline" placeholder="Май 2027" readonly="state not in ['draft', 'rejected']"/>
                        </group>
                    </group>

                    <group>
                        <group string="Образовательное учреждение" icon="fa-university">
                            <field name="institute" placeholder="Естественных наук и математики" readonly="state not in ['draft', 'rejected']"/>
                            <field name="department" placeholder="Департамент..." readonly="state not in ['draft', 'rejected']"/>
                        </group>
                        <group string="Образовательная программа" icon="fa-graduation-cap">
                            <field name="specialty_code" placeholder="02.04.01" readonly="state not in ['draft', 'rejected']"/>
                            <field name="program" placeholder="Современные проблемы компьютерных наук" readonly="state not in ['draft', 'rejected']"/>
                        </group>
                    </group>

                    <group string="Научно-исследовательская деятельность" icon="fa-flask">
                        <field name="research_area" placeholder="Опишите направление исследований..." nolabel="1" readonly="state not in ['draft', 'rejected']"/>
                        <field name="thesis_topic" placeholder="Тема выпускной квалификационной работы..." nolabel="1" readonly="state not in ['draft', 'rejected']"/>
                    </group>

                    <!-- Блок для преподавателя: комментарий при проверке -->
                    <group string="Проверка преподавателя" icon="fa-comment"
                           invisible="state != 'submitted'" groups="ic_urfu_module.group_ic_urfu_teacher">
                        <field name="teacher_comment" placeholder="Напишите комментарий к плану..." nolabel="1"/>
                    </group>

                    <notebook>
                        <page string="Семестры" name="semesters" icon="fa-calendar-check-o">
                            <field name="semester_ids" readonly="state not in ['draft', 'rejected']">
                                <tree string="Семестры" editable="bottom">
                                    <field name="number" widget="integer" readonly="0" force_save="1" required="1"/>
                                    <field name="academic_year" readonly="0"/>
                                    <field name="mandatory_subject_ids" widget="many2many_tags"
                                           options="{'color_field': 'subject_type', 'no_create': True}"/>
                                    <field name="elective_subject_ids" widget="many2many_tags"
                                           options="{'color_field': 'subject_type', 'no_create': True}"/>
                                </tree>
                                <form string="Семестр">
                                    <sheet>
                                        <div class="oe_title">
                                            <label for="number"/>
                                            <h1>
                                                <field name="number" class="oe_inline"/> семестр
                                            </h1>
                                        </div>
                                        <group>
                                            <field name="academic_year"/>
                                        </group>

                                        <separator string="Обязательные дисциплины" icon="fa-book"/>
                                        <field name="mandatory_subject_ids" nolabel="1">
                                            <kanban class="o_kanban_mobile">
                                                <field name="name"/>
                                                <field name="hours"/>
                                                <field name="credits"/>
                                                <field name="control"/>
                                                <templates>
                                                    <t t-name="kanban-box">
                                                        <div class="oe_kanban_global_click">
                                                            <div class="o_kanban_record_top">
                                                                <div class="o_kanban_record_headings">
                                                                    <strong><field name="name"/></strong>
                                                                </div>
                                                            </div>
                                                            <div class="o_kanban_record_bottom">
                                                                <div class="oe_kanban_bottom_left">
                                                                    <span><i class="fa fa-clock-o"/> <field name="hours"/> ч</span>
                                                                    <span class="ml8"><i class="fa fa-trophy"/> <field name="credits"/> ЗЕТ</span>
                                                                </div>
                                                                <div class="oe_kanban_bottom_right">
                                                                    <field name="control" widget="badge"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </t>
                                                </templates>
                                            </kanban>
                                        </field>

                                        <separator string="Дисциплины по выбору" icon="fa-list-ul"/>
                                        <field name="elective_subject_ids" nolabel="1">
                                            <kanban class="o_kanban_mobile">
                                                <field name="name"/>
                                                <field name="hours"/>
                                                <field name="credits"/>
                                                <field name="control"/>
                                                <templates>
                                                    <t t-name="kanban-box">
                                                        <div class="oe_kanban_global_click">
                                                            <div class="o_kanban_record_top">
                                                                <div class="o_kanban_record_headings">
                                                                    <strong><field name="name"/></strong>
                                                                </div>
                                                            </div>
                                                            <div class="o_kanban_record_bottom">
                                                                <div class="oe_kanban_bottom_left">
                                                                    <span><i class="fa fa-clock-o"/> <field name="hours"/> ч</span>
                                                                    <span class="ml8"><i class="fa fa-trophy"/> <field name="credits"/> ЗЕТ</span>
                                                                </div>
                                                                <div class="oe_kanban_bottom_right">
                                                                    <field name="control" widget="badge"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </t>
                                                </templates>
                                            </kanban>
                                        </field>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <page string="Сгенерированный документ" name="document" icon="fa-file-word-o"
                              invisible="not document_file">
                            <div class="text-center" style="padding: 40px;">
                                <i class="fa fa-file-word-o fa-5x text-success mb16"/>
                                <h3>Документ успешно сгенерирован</h3>
                                <p class="text-muted">Имя файла: <field name="document_filename" readonly="1"/></p>
                                <field name="document_file" filename="document_filename" widget="binary"
                                       string="Скачать документ" class="btn btn-lg btn-success"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action для планов -->
    <record id="action_ic_urfu_plan" model="ir.actions.act_window">
        <field name="name">Индивидуальные планы</field>
        <field name="res_model">ic.urfu.plan</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_ic_urfu_plan_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Создайте первый индивидуальный учебный план
            </p>
            <p>
                Заполните информацию о студенте, выберите дисциплины по семестрам,
                и сгенерируйте документ в формате DOCX.
            </p>
        </field>
    </record>

    <!-- Action для преподавателей: планы на проверке -->
    <record id="action_ic_urfu_plan_teacher_review" model="ir.actions.act_window">
        <field name="name">Заявки на утверждение</field>
        <field name="res_model">ic.urfu.plan</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_ic_urfu_plan_search"/>
        <field name="domain">[('state', '=', 'submitted')]</field>
        <field name="context">{'search_default_filter_submitted': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Нет заявок на проверку
            </p>
            <p>
                Студенты еще не отправили планы на проверку.
            </p>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- МЕНЮ -->
    <!-- ========================================= -->

    <!-- Главное меню -->
    <menuitem id="menu_ic_urfu_root" name="IC UrFU" sequence="10" web_icon="ic_urfu_module,static/description/icon.png"/>

    <!-- Подменю: Планы -->
    <menuitem id="menu_ic_urfu_plans" name="Планы" parent="menu_ic_urfu_root" sequence="10"/>
    <menuitem id="menu_ic_urfu_plan_list" name="Индивидуальные планы" parent="menu_ic_urfu_plans"
              action="action_ic_urfu_plan" sequence="10"/>
    <menuitem id="menu_ic_urfu_plan_review" name="Заявки на утверждение" parent="menu_ic_urfu_plans"
              action="action_ic_urfu_plan_teacher_review" sequence="20"
              groups="ic_urfu_module.group_ic_urfu_teacher"/>

    <!-- Подменю: Справочники -->
    <menuitem id="menu_ic_urfu_config" name="Справочники" parent="menu_ic_urfu_root" sequence="90"/>
    <menuitem id="menu_ic_urfu_subjects" name="Дисциплины" parent="menu_ic_urfu_config"
              action="action_ic_urfu_subject" sequence="10"/>

</odoo>
