<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Settings Form View -->
    <record id="view_ic_urfu_config_settings" model="ir.ui.view">
        <field name="name">ic.urfu.config.settings.form</field>
        <field name="model">ic.urfu.config.settings</field>
        <field name="arch" type="xml">
            <form string="IC UrFU Settings" class="oe_form_configuration">
                <header>
                    <button string="Сохранить" type="object" name="execute" class="oe_highlight"/>
                    <button string="Отмена" type="object" name="cancel" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="app_settings_block" data-key="ic_urfu_document">
                        <h2>Настройки генерации документов</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="default_document_font"/>
                                    <div class="text-muted">
                                        Шрифт для генерируемых документов DOCX
                                    </div>
                                    <field name="default_document_font" class="o_light_label"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="default_document_font_size"/>
                                    <div class="text-muted">
                                        Размер шрифта документа в пунктах
                                    </div>
                                    <field name="default_document_font_size" class="o_light_label"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="app_settings_block" data-key="ic_urfu_defaults">
                        <h2>Значения по умолчанию</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="default_hours"/>
                                    <div class="text-muted">
                                        Объем аудиторной работы по умолчанию для новых дисциплин
                                    </div>
                                    <field name="default_hours" class="o_light_label"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="default_credits"/>
                                    <div class="text-muted">
                                        Количество ЗЕТ по умолчанию для новых дисциплин
                                    </div>
                                    <field name="default_credits" class="o_light_label"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="default_control_form"/>
                                    <div class="text-muted">
                                        Форма аттестации по умолчанию
                                    </div>
                                    <field name="default_control_form" class="o_light_label"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="app_settings_block" data-key="ic_urfu_institution">
                        <h2>Настройки учреждения</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="default_institute"/>
                                    <div class="text-muted">
                                        Институт, автоматически подставляется в новые планы
                                    </div>
                                    <field name="default_institute" class="o_light_label"
                                           placeholder="Естественных наук и математики"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="default_department"/>
                                    <div class="text-muted">
                                        Кафедра/Департамент по умолчанию
                                    </div>
                                    <field name="default_department" class="o_light_label"
                                           placeholder="Школа наук"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="app_settings_block" data-key="ic_urfu_workflow">
                        <h2>Настройки workflow</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="notification_enabled"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="notification_enabled"/>
                                    <div class="text-muted">
                                        Отправлять уведомления студентам при изменении статуса плана
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Settings Action -->
    <record id="action_ic_urfu_config" model="ir.actions.act_window">
        <field name="name">Настройки IC UrFU</field>
        <field name="res_model">ic.urfu.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{}</field>
    </record>

    <!-- Settings Menu Item -->
    <menuitem id="menu_ic_urfu_settings"
              name="Настройки"
              parent="menu_ic_urfu_root"
              action="action_ic_urfu_config"
              sequence="100"
              groups="base.group_system"/>
</odoo>
